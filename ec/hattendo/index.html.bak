<script>
  $(function () {
    // IE11 sticky
    var elements = document.querySelectorAll('.sticky');
    Stickyfill.add(elements);

    var $ofi_cover = $('img.ofi_cover');
    objectFitImages($ofi_cover);

    $("img.lazyload").lazyload();

    new ClipboardJS('.coupon_ticket_trial_code_copy');
    $(document).on('click', '.coupon_ticket_trial_code_copy', function () {
      $('.coupon_ticket_trial_code_text').addClass('tooltip');
      setTimeout((function () {
        $('.coupon_ticket_trial_code_text').removeClass('tooltip');
      }), 2500);
    });

    // クーポンURL取得
    axios.get('/docs/ec/assets/coupon.json')
      .then(function (response) {
        var result = response.data.hattendo;
        if (result) {
          for (var i = 0; i < result.length; i++) {
            $('.' + result[i]['coupon_id'] + '').attr('href', result[i]['coupon_url']);
          }
        }
      })
      .catch(function (error) {
        console.log('取得失敗', error);
      })
      .then(function () {
      });
  });
</script>

<body>
  <header class="header">
    <div class="header_wrap">
      <h1 class="header_logo">
        <a href="https://epark.jp/"><img src="./images/1x/logo_EPARK.svg" alt="EPARK 人気施設の予約・順番受付サイト"></a>
      </h1>
    </div>
  </header>
  <main>
    <div class="bread_crumb">
      <div class="inner">
        <ul>
          <li><a href="/">EPARK</a></li>
          <li><a href="/docs/ec/gift/">EPARKギフト ブランド一覧</a></li>
          <li>八天堂</li>
        </ul>
      </div>
    </div>
    <section class="section_mv">
      <div class="inner">
        <picture>
          <source media="(min-width: 568px)" srcset="images/1x/KV_PC.jpg, images/2x/KV_PC@2x.jpg 2x">
          <source media="(max-width: 567px)" srcset="images/1x/KV_SP.jpg, images/2x/KV_SP@2x.jpg 2x, images/3x/KV_SP@3x.jpg 3x">
          <img class="ofi_cover" src="images/1x/KV_PC.jpg" srcset="images/1x/KV_PC.jpg, images/2x/KV_PC@2x.jpg 2x" alt="八天堂">
        </picture>
      </div>
    </section>
    <section class="section_01">
      <div class="inner">
        <h2>「八天堂」とは</h2>
        <p class="lead">昭和8年、創業者の森光香が「甘くておいしい和菓子を通じて、少しでも周りの人たちを元気づけたい」という想いで和菓子屋をはじめたのが、八天堂の始まりです。それから80年、「和」と「洋」の技術を融合させ、生まれた“くりーむパン”は、広島から全国へ、さらには海外へと広がっています。くりーむパンが世界中で共通のことばになる日まで、わたしたちは走りつづけます。</p>
      </div>
    </section>
    <section class="nav sticky">
      <div class="inner">
        <ul>
          <li><a href="#howto-use">ご利用の<br class="sp_br">流れ</a></li>
          <li><a href="#select-coupon">クーポンを<br class="sp_br">選ぶ</a></li>
          <li><a href="#product-info">おすすめ<br class="sp_br">商品</a></li>
          <li><a href="#attention">注意事項<br class="sp_br">・FAQ</a></li>
        </ul>
      </div>
    </section>
    <a id="howto-use" class="anchor"></a>
    <section class="section_02">
      <div class="inner">
        <h2>ご利用の流れ</h2>
        <div class="step">
          <div class="step_box">
            <div class="step_box_image sp">
              <img src="../assets/images/1x/step1.png" srcset="../assets/images/1x/step1.png, ../assets/images/2x/step1@2x.png 2x, ../assets/images/3x/step1@3x.png 3x" alt="STEP1">
            </div>
            <div class="step_box_flex">
              <div class="step_box_head">STEP1</div>
              <div class="step_box_image pc">
                <img src="../assets/images/1x/step1.png" srcset="../assets/images/1x/step1.png, ../assets/images/2x/step1@2x.png 2x" alt="STEP1">
              </div>
              <div class="step_box_text">
                <a href="#product-info">おすすめ商品</a>、または<br class="pc_br">
                <a href="https://hattendo.jp/">ブランドサイト</a>で商品を選ぶ
              </div>
            </div>
          </div>
          <div class="step_box">
            <div class="step_box_image sp">
              <img src="../assets/images/1x/step2.png" srcset="../assets/images/1x/step2.png, ../assets/images/2x/step2@2x.png 2x, ../assets/images/3x/step2@3x.png 3x" alt="STEP2">
            </div>
            <div class="step_box_flex">
              <div class="step_box_head">STEP2</div>
              <div class="step_box_image pc">
                <img src="../assets/images/1x/step2.png" srcset="../assets/images/1x/step2.png, ../assets/images/2x/step2@2x.png 2x" alt="STEP2">
              </div>
              <div class="step_box_text">
                <a href="#select-coupon">クーポンを選ぶ</a>から<br>
                お好みのクーポンを選ぶ
              </div>
            </div>
          </div>
          <div class="step_box">
            <div class="step_box_image sp">
              <picture>
                <source media="(min-width: 568px)" srcset="images/1x/step3_pc.png, images/2x/step3_pc@2x.png 2x">
                <source media="(max-width: 567px)" srcset="images/1x/step3_sp.png, images/2x/step3_sp@2x.png 2x, images/3x/step3_sp@3x.png 3x">
                <img src="images/1x/step3_pc.png" srcset="images/1x/step3_pc.png, images/2x/step3_pc@2x.png 2x" alt="STEP3">
              </picture>
            </div>
            <div class="step_box_flex">
              <div class="step_box_head">STEP3</div>
              <div class="step_box_image pc">
                <picture>
                  <source media="(min-width: 568px)" srcset="images/1x/step3_pc.png, images/2x/step3_pc@2x.png 2x">
                  <source media="(max-width: 567px)" srcset="images/1x/step3_sp.png, images/2x/step3_sp@2x.png 2x, images/3x/step3_sp@3x.png 3x">
                  <img src="images/1x/step3_pc.png" srcset="images/1x/step3_pc.png, images/2x/step3_pc@2x.png 2x" alt="STEP3">
                </picture>
              </div>
              <div class="step_box_text">
                <a href="https://hattendo.jp/"> ブランドサイト</a>で商品を選択し、<br class="pc_br">クーポンコードを入力して注文
              </div>
            </div>
