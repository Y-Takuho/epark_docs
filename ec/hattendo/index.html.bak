                      <img class="lazyload" src="../assets/images/1x/lazyload.gif" data-src="../assets/images/1x/pc-try500.png" srcset="../assets/images/1x/pc-try500.png, ../assets/images/2x/pc-try500@2x.png 2x" alt="">
                    </picture>
                  </div>
                  <div class="coupon_ticket_trial_code">
                    <div class="coupon_ticket_trial_code_text">
                      hd002
                    </div>
                    <div class="coupon_ticket_trial_code_copy" data-clipboard-text="hd002">
                      コピーする
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <a id="coupon" class="anchor_coupon"></a>
          <div class="coupon_box">
            <h3>割引クーポン</h3>
            <div class="coupon_ticket_wrap">
              <div class="coupon_ticket_box">
                <h4>いくらからでもご利用OK</h4>
                <div class="coupon_ticket">
                  <a class="coupon_ticket_image coupon500">
                    <picture>
                      <source media="(min-width: 568px)" srcset="../assets/images/1x/pc-coupon500.png, ../assets/images/2x/pc-coupon500@2x.png 2x">
                      <source media="(max-width: 567px)" srcset="../assets/images/1x/sp-coupon500.png, ../assets/images/2x/sp-coupon500@2x.png 2x, ../assets/images/3x/sp-coupon500@3x.png 3x">
                      <img class="lazyload" src="../assets/images/1x/lazyload.gif" data-src="../assets/images/1x/pc-coupon500.png" srcset="../assets/images/1x/pc-coupon500.png, ../assets/images/2x/pc-coupon500@2x.png 2x" alt="">
                    </picture>
                  </a>
                </div>
              </div>
              <div class="coupon_ticket_box">
                <h4>いくらからでもご利用OK</h4>
                <div class="coupon_ticket">
                  <a class="coupon_ticket_image coupon810">
                    <picture>
                      <source media="(min-width: 568px)" srcset="../assets/images/1x/pc-coupon810.png, ../assets/images/2x/pc-coupon810@2x.png 2x">
                      <source media="(max-width: 567px)" srcset="../assets/images/1x/sp-coupon810.png, ../assets/images/2x/sp-coupon810@2x.png 2x, ../assets/images/3x/sp-coupon810@3x.png 3x">
                      <img class="lazyload" src="../assets/images/1x/lazyload.gif" data-src="../assets/images/1x/pc-coupon810.png" srcset="../assets/images/1x/pc-coupon810.png, ../assets/images/2x/pc-coupon810@2x.png 2x" alt="">
                    </picture>
                  </a>
                </div>
              </div>
              <div class="coupon_ticket_box">
                <h4>いくらからでもご利用OK</h4>
                <div class="coupon_ticket">
                  <a class="coupon_ticket_image coupon1000">
