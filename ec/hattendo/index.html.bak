                      <source media="(min-width: 568px)" srcset="../assets/images/1x/pc-coupon1000.png, ../assets/images/2x/pc-coupon1000@2x.png 2x">
                      <source media="(max-width: 567px)" srcset="../assets/images/1x/sp-coupon1000.png, ../assets/images/2x/sp-coupon1000@2x.png 2x, ../assets/images/3x/sp-coupon1000@3x.png 3x">
